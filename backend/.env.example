# SQLite for local dev; swap to PostgreSQL for production
DATABASE_URL=sqlite:///./code_review.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/db_name

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_very_secure_32_char_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Groq API key — get yours at https://console.groq.com
GROQ_API_KEY=gsk_your_actual_api_key_here

# Default model — must be one of the SUPPORTED_MODELS in review_request.py
# Options: deepseek-r1-distill-llama-70b | llama-3.3-70b-versatile | qwen-qwq-32b
AI_MODEL=llama-3.3-70b-versatile

# Live frontend URL for CORS (update for production deployment)
FRONTEND_URL=http://localhost:5173
